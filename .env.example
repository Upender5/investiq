# Copy this file to .env and fill in real values before running docker-compose.
# Never commit .env to git.

# ── PostgreSQL (TimescaleDB) ─────────────────────────────────────────────────
POSTGRES_USER=investiq
POSTGRES_PASSWORD=change-me
POSTGRES_DB=investiq          # root/admin database; service DBs are created by init.sh

# ── Redis 7 ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me

# ── MongoDB 7 ────────────────────────────────────────────────────────────────
MONGO_USERNAME=investiq
MONGO_PASSWORD=change-me

# ── Kafka ────────────────────────────────────────────────────────────────────
# Services inside Docker connect to kafka:9092
# Local tools (e.g. kcat, kafka-ui) connect to localhost:9094
KAFKA_HEAP_OPTS=-Xmx512m -Xms256m

# ── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@investiq.local
PGADMIN_PASSWORD=change-me

# ── auth-service ─────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/investiq_auth
DB_USERNAME=investiq
DB_PASSWORD=change-me         # same as POSTGRES_PASSWORD

REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRY_MS=900000      # 15 min
JWT_REFRESH_EXPIRY_MS=604800000  # 7 days

# OTP / SMS
OTP_EXPIRY_SECONDS=300
SMS_PROVIDER=logging             # logging (dev) | msg91 (prod)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
