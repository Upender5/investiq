# =============================================================
# InvestIQ — root .gitignore
# =============================================================

# ── SECRETS (NEVER commit these) ─────────────────────────────
.env
.env.*
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.jks
fcm.json
firebase-credentials.json
google-services.json
GoogleService-Info.plist

# ── Java / Maven ─────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
*.log
hs_err_pid*
replay_pid*
.mvn/wrapper/maven-wrapper.jar

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.Python
.venv/
venv/
env/
ENV/
.env/
dist/
build/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.hypothesis/

# ── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/
.npm/
package-lock.json
yarn.lock

# ── Next.js ──────────────────────────────────────────────────
.next/
out/
.vercel/
next-env.d.ts

# ── Expo / React Native ───────────────────────────────────────
.expo/
.expo-shared/
expo-env.d.ts
dist/
web-build/
android/
ios/
*.jsbundle

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ── IDE & OS ─────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Kubernetes secrets (never commit filled secrets) ─────────
infra/k8s/secrets/*.yaml

# ── Claude Code internal ─────────────────────────────────────
.claude/settings.local.json
